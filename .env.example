# =============================================================================
# AI Assistant MVP - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# At least one of OPENAI_API_KEY or ANTHROPIC_API_KEY must be set.

# -----------------------------------------------------------------------------
# AI Provider API Keys (at least one required)
# -----------------------------------------------------------------------------

# OpenAI API key — required to use GPT models (gpt-3.5-turbo, gpt-4)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API key — required to use Claude models (claude-3-sonnet, claude-3-opus)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI API key — required to use Gemini models (gemini-1.5-pro, gemini-1.5-flash)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# Path to the SQLite database file (will be created if it doesn't exist)
# Default: ./data/sessions.db
DATABASE_PATH=./data/sessions.db

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Port the HTTP server listens on
# Default: 3000
PORT=3000

# Hostname or IP address to bind to
# Default: localhost (use 0.0.0.0 to listen on all interfaces)
HOST=localhost

# -----------------------------------------------------------------------------
# Application Environment
# -----------------------------------------------------------------------------

# Runtime environment: development | production | test
# Default: development
NODE_ENV=development

# Enable verbose debug logging (true | false)
# Default: false
DEBUG=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: error | warn | info | debug
# Default: info
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Channel Configuration (optional)
# -----------------------------------------------------------------------------

# Telegram Bot Token (from @BotFather)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of allowed Telegram chat IDs (empty = allow all)
# TELEGRAM_ALLOWED_CHATS=123456789,987654321

# Discord Bot Token
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Comma-separated list of allowed Discord guild IDs
# DISCORD_ALLOWED_GUILDS=guild_id_1,guild_id_2

# Slack Bot Token and Signing Secret
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_SIGNING_SECRET=your_slack_signing_secret
# SLACK_APP_TOKEN=xapp-your-slack-app-token
